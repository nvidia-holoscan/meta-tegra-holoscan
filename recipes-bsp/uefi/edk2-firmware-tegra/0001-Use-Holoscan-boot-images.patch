From: Ilies CHERGUI <ichergui@nvidia.com>
Date: Thu, 26 Jun 2025 15:47:37 +0100
Subject: [PATCH] Use Holoscan boot images

Signed-off-by: Ian Stewart <istewart@nvidia.com>
---
 Platform/NVIDIA/NVIDIA.fvmain.fdf.inc | 6 +++---
 1 file changed, 3 insertions(+), 3 deletions(-)

diff --git a/Platform/NVIDIA/NVIDIA.fvmain.fdf.inc b/Platform/NVIDIA/NVIDIA.fvmain.fdf.inc
index e273ea91..1da960e6 100644
--- a/Platform/NVIDIA/NVIDIA.fvmain.fdf.inc
+++ b/Platform/NVIDIA/NVIDIA.fvmain.fdf.inc
@@ -240,9 +240,9 @@ FvNameGuid         = $(PLATFORM_GUID)
   # Logo Files
   #
   FILE FREEFORM = gNVIDIAPlatformLogoGuid {
-    SECTION RAW = Silicon/NVIDIA/Assets/nvidiagray480.bmp
-    SECTION RAW = Silicon/NVIDIA/Assets/nvidiagray720.bmp
-    SECTION RAW = Silicon/NVIDIA/Assets/nvidiagray1080.bmp
+    SECTION RAW = Silicon/NVIDIA/Assets/holoscan-480.bmp
+    SECTION RAW = Silicon/NVIDIA/Assets/holoscan-720.bmp
+    SECTION RAW = Silicon/NVIDIA/Assets/holoscan-1080.bmp
   }
 !endif
 
