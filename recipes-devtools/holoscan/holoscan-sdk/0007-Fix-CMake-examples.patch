 .../matx_allocator/cpp/CMakeLists.min.txt     | 31 +++----------------
 .../matx/matx_basic/cpp/CMakeLists.min.txt    | 31 +++----------------
 .../core/resources/data_logger_queue.hpp      |  2 +-
 .../holoinfer/src/infer/torch/CMakeLists.txt  | 19 ++----------
 4 files changed, 14 insertions(+), 69 deletions(-)

diff --git a/examples/matx/matx_allocator/cpp/CMakeLists.min.txt b/examples/matx/matx_allocator/cpp/CMakeLists.min.txt
index c88c04075..c4d56277b 100644
--- a/examples/matx/matx_allocator/cpp/CMakeLists.min.txt
+++ b/examples/matx/matx_allocator/cpp/CMakeLists.min.txt
@@ -26,32 +26,11 @@ elseif(CMAKE_CUDA_ARCHITECTURES MATCHES "^[0-9]+$" AND CMAKE_CUDA_ARCHITECTURES
   set(CMAKE_CUDA_ARCHITECTURES "70")
 endif()
 
-find_package(CUDAToolkit QUIET)
-if(CUDAToolkit_VERSION VERSION_GREATER_EQUAL 13.0)
-  set(MATX_CCCL_MIN_VERSION 3.0)
-else()
-  set(MATX_CCCL_MIN_VERSION 2.8)
-endif()
-
-# Holoscan SDK core features depend on CCCL >= 2.5 while the optional holoscan::matx feature
-# depends on CCCL >= 2.8. Skip this example if no compatible CCCL is found.
-if(MATX_CCCL_MIN_VERSION VERSION_GREATER_EQUAL 3.0)
-  find_package(CCCL ${MATX_CCCL_MIN_VERSION} PATHS /usr/local/cuda/lib64/cmake/cccl)
-else()
-  # Allow compatibility across CCCL major versions
-  find_package(CCCL 3.0 PATHS /usr/local/cuda/lib64/cmake/cccl QUIET)
-  if(NOT CCCL_FOUND)
-    find_package(CCCL ${MATX_CCCL_MIN_VERSION} PATHS /usr/local/cuda/lib64/cmake/cccl QUIET)
-  endif()
-endif()
-
-if(NOT CCCL_FOUND)
-  message(STATUS "CCCL not found or version too old. Need at least CCCL ${MATX_CCCL_MIN_VERSION} for MatX.
-Please install a compatible CCCL version from https://github.com/NVIDIA/cccl.git
-and re-configure the project with -DCCCL_ROOT=path/to/cccl to resolve the issue.
-Skipping the matx_allocator example...")
-  return()
-endif()
+find_package(CCCL REQUIRED)
+find_package(CUB REQUIRED)
+find_package(libcudacxx REQUIRED)
+find_package(Thrust REQUIRED)
+find_package(matx 0.9.4 REQUIRED)
 
 # Finds the package holoscan
 find_package(holoscan REQUIRED CONFIG
diff --git a/examples/matx/matx_basic/cpp/CMakeLists.min.txt b/examples/matx/matx_basic/cpp/CMakeLists.min.txt
index 168d5944d..8d86a107a 100644
--- a/examples/matx/matx_basic/cpp/CMakeLists.min.txt
+++ b/examples/matx/matx_basic/cpp/CMakeLists.min.txt
@@ -26,32 +26,11 @@ elseif(CMAKE_CUDA_ARCHITECTURES MATCHES "^[0-9]+$" AND CMAKE_CUDA_ARCHITECTURES
   set(CMAKE_CUDA_ARCHITECTURES "70")
 endif()
 
-find_package(CUDAToolkit QUIET)
-if(CUDAToolkit_VERSION VERSION_GREATER_EQUAL 13.0)
-  set(MATX_CCCL_MIN_VERSION 3.0)
-else()
-  set(MATX_CCCL_MIN_VERSION 2.8)
-endif()
-
-# Holoscan SDK core features depend on CCCL >= 2.5 while the optional holoscan::matx feature
-# depends on CCCL >= 2.8. Skip this example if no compatible CCCL is found.
-if(MATX_CCCL_MIN_VERSION VERSION_GREATER_EQUAL 3.0)
-  find_package(CCCL ${MATX_CCCL_MIN_VERSION} PATHS /usr/local/cuda/lib64/cmake/cccl)
-else()
-  # Allow compatibility across CCCL major versions
-  find_package(CCCL 3.0 PATHS /usr/local/cuda/lib64/cmake/cccl QUIET)
-  if(NOT CCCL_FOUND)
-    find_package(CCCL ${MATX_CCCL_MIN_VERSION} PATHS /usr/local/cuda/lib64/cmake/cccl QUIET)
-  endif()
-endif()
-
-if(NOT CCCL_FOUND)
-  message(STATUS "CCCL not found or version too old. Need at least CCCL ${MATX_CCCL_MIN_VERSION} for MatX.
-Please install a compatible CCCL version from https://github.com/NVIDIA/cccl.git
-and re-configure the project with -DCCCL_ROOT=path/to/cccl to resolve the issue.
-Skipping the matx_basic example...")
-  return()
-endif()
+find_package(CCCL REQUIRED)
+find_package(CUB REQUIRED)
+find_package(libcudacxx REQUIRED)
+find_package(Thrust REQUIRED)
+find_package(matx 0.9.4 REQUIRED)
 
 # Finds the package holoscan
 find_package(holoscan REQUIRED CONFIG
